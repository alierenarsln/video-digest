# --- Transkripsiyon (Groq free tier) ---
# https://console.groq.com/keys adresinden ücretsiz alınır
GROQ_API_KEY=gsk_...
GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo

# --- Özetleme ---
# Anthropic anahtarı OPSİYONEL. Yoksa özet katmanı Groq'ta koşar (aynı ücretsiz
# anahtar). Varsa kalite belirgin daha iyi (özellikle eleştirmen geçişi), 1M bağlam,
# dakikalık kota derdi yok.
ANTHROPIC_API_KEY=
SUMMARY_MODEL=claude-opus-4-8

# --- OpenRouter (ücretsiz modeller) — opsiyonel ---
# https://openrouter.ai/keys
# Groq ile ZIT kısıt: token kotası değil, GÜNDE 50 İSTEK (kredi 0 iken; $10 kredi
# alınırsa 1000/gün) + dakikada 20. Bir video ~12-15 istek → günde ~3 video.
# Karşılığında 262k bağlam: tüm transkript tek istekte bölümlenir (daha iyi
# bölümleme). Groq'ta günlük sınır yok → sınırsız video ama daha yavaş.
OPENROUTER_API_KEY=
# ÖLÇÜLDÜ (ücretsiz + katı JSON şeması destekleyenler, TEKRARLI deneme):
#   google/gemma-4-26b-a4b-it:free -> 6/6 sağlam, verimli            (varsayılan)
#   tencent/hy3:free               -> GÜVENİLMEZ: 3'te 1 boş/kesik JSON. Tek
#                                     testte iyi görünüp aldatıyor.
#   nvidia/nemotron-3-super-120b   -> 1M bağlam ama 3/3 tek jenerik bölüm (KÖTÜ)
#   openai/gpt-oss-20b:free        -> boş yanıt
# Model değiştirirseniz TEK denemeye güvenmeyin, en az 3 kez ölçün.
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_MAX_OUTPUT=8000

# Gemini — LLM kıyasında bu iş için fiyat/kalite dengesinin kazananı.
# Native yapısal JSON (gemma flake'i yok), iyi Türkçe, 1M bağlam, ~$3/ay.
# Anahtar: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 2.5-flash: denge (varsayılan). 2.5-flash-lite: daha ucuz, biraz zayıf.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT=8000

# anthropic | groq | openrouter | gemini
# (boş = anahtar varsa anthropic > gemini > groq)
LLM_PROVIDER=

# Groq'ta KATI JSON şeması destekleyen model. ÖLÇÜLDÜ: gpt-oss-120b ve gpt-oss-20b
# destekliyor; llama-3.3-70b ve qwen3 DESTEKLEMİYOR (HTTP 400). Değiştirirken
# doğrulayın, yoksa her istek düşer.
GROQ_LLM_MODEL=openai/gpt-oss-120b

# ÜCRETSİZ KATMANIN ASIL SINIRI BAĞLAM DEĞİL, DAKİKALIK TOKEN KOTASI (ölçüldü:
# gpt-oss = 8000, llama-4-scout = 30000). Groq bu bütçeye istenen max_tokens'ı DA
# sayar; kotadan büyük tek bir istek ASLA geçmez (413) — beklemek çözmez, bölmek
# gerekir. Boru hattı bu yüzden pencereli çalışıyor.
GROQ_TPM=8000
# Kota küresel; eşzamanlı istek kotayı anında doldurup herkesi 429'a sokuyor.
# Paralellik burada hız kazandırmıyor. 1 = sırayla.
GROQ_CONCURRENCY=1

# Özet hangi dilde yazılsın? Boş = kaynağın dili.
# Boş bırakmak dil karışmasına yol açabiliyor (prompt'lar Türkçe, kaynak İngilizce
# → başlık Türkçe, özet İngilizce). İngilizce kursun Türkçe özeti asıl kullanım.
OUTPUT_LANGUAGE=Türkçe

# --- Erişim koruması ---
# BOŞ = koruma yok. Yalnızca 127.0.0.1'e bağlıyken (yerel kullanım) güvenli.
# Docker/Coolify'da ZORUNLU: konteyner şifresiz açılmayı reddeder, çünkü servis
# internete açık ve korumasız kalırsa linki bulan herkes API kotanızı yakabilir.
APP_USER=admin
APP_PASSWORD=

# --- Sunucu ---
PORT=8080
DATA_DIR=/data

# İşlenen sesin parçalara bölünme uzunluğu (saniye).
# Groq'un istek başına dosya boyutu limitine takılmamak için.
CHUNK_SECONDS=600

# Groq'a aynı anda gönderilecek parça sayısı (free tier rate limit'e dikkat)
TRANSCRIBE_CONCURRENCY=3

# Whisper'a verilecek dil. Boş bırakılırsa otomatik algılanır.
# DİKKAT: bu bir zorlamadır, ipucu değil. "tr" yazıp İngilizce video işlerseniz
# çıktı bozulur. Yalnızca TÜM içeriğiniz aynı dildeyse doldurun; karışıksa boş bırakın.
TRANSCRIBE_LANGUAGE=

# --- Altyazı: varsa Whisper'a hiç gitmeden bedava ve anlık transkript ---
USE_SUBTITLES=true

# Tercih edilen altyazı dilleri (virgülle). BOŞ = videonun kendi dili — önerilen,
# çünkü Whisper'ın üreteceğinin sadık karşılığıdır.
# "tr,en" derseniz İngilizce videonun elle yazılmış TÜRKÇE çevirisi varsa o kullanılır
# ve özet de Türkçe çıkar. Makine çevirileri asla seçilmez.
SUBTITLE_LANGS=

# YouTube'un otomatik (ASR) altyazısı da kabul edilsin mi? Kalitesi dile göre değişir
# ve Whisper genelde daha iyi olduğu için varsayılan kapalı. Açılsa bile yalnızca
# videonun ORİJİNAL dilinde kullanılır (diğer diller makine çevirisidir).
ALLOW_AUTO_SUBTITLES=false

# --- Transkript onarımı: bölük pörçük metni anlamlı cümlelere çevirir ---
# Zaman damgaları korunur; ekran metni (OCR) varsa terim/özel isim düzeltmede kullanılır.
# auto=kalite düşükse onar | always=her zaman | off=hiç
REPAIR_MODE=auto

# Eşikler ölçülerek kalibre edildi. Noktalama yoğunluğu KALİTEYİ değil cümle
# uzunluğunu ölçer (elle yazılmış altyazı 3.9, otomatik 5.0 alıyor!), bu yüzden
# eşik yalnızca "hiç noktalama yok" halini yakalar. Asıl ayrımı büyük-harf oranı
# yapıyor: elle yazılmış 0.45, otomatik 0.10 (satırlar cümle ortasından bölünmüş).
REPAIR_MIN_PUNCT=1.0
REPAIR_MIN_CAPS=0.15

# İş bitince n8n'e haber verilecek adres (opsiyonel; iş başına da verilebilir)
DEFAULT_CALLBACK_URL=

# --- Görsel katman: slayt yakalama + OCR (Faz 2) ---
# Kapatırsanız yalnızca ses indirilir; iş belirgin hızlanır ama slaytta yazıp
# söylenmeyen bilgi özete girmez.
ENABLE_FRAMES=true
VIDEO_MAX_HEIGHT=720

# Sahne tespiti eşiği. Düşür = daha çok slayt yakalar (hassas), yükselt = daha az.
SCENE_THRESHOLD=27.0

# Algısal hash mesafesi; bunun altındaki kareler "aynı" sayılıp elenir.
# Yükseltirseniz benzer slaytlar da elenir, düşürürseniz tekrar artar.
PHASH_DISTANCE=5

# OCR dilleri. Dockerfile tur+eng kurar; başka dil eklerseniz paketini de ekleyin.
OCR_LANGS=tur+eng

# --- Yalnızca Docker'sız (yerel) kurulum için ---
# Docker imajında tesseract PATH'te ve dil paketleri yerinde olduğundan bu iki
# satır Docker'da BOŞ bırakılmalı.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSDATA_PREFIX=C:\Users\Alier\video-digest\tessdata

# Bu kadar bile metni olmayan kare slayt sayılmaz (konuşan kafa) — atılır.
MIN_OCR_CHARS=15

# Özete gömülecek azami slayt sayısı. Aşılırsa eşit aralıkla seyreltilir.
MAX_FRAMES=80
